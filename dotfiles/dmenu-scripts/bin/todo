#!/bin/sh
#
# Task management via rofi.
#
# Opens a rofi menu showing incomplete tasks from a markdown file.
# Type a new entry to add it as "- [ ] <task>".
# Select an existing entry to mark it as complete "- [x] <task> (YYYY-mm-dd)".
# Completed tasks are hidden from the menu but remain in the file.

file="$HOME/Documents/jn/todo.md"
mkdir -p "$(dirname "$file")"
touch "$file"

prompt="Add/complete a task: "

show_menu() {
    incomplete=$(grep '^- \[ \] ' "$file" | sed 's/^- \[ \] //')
    if [ -n "$incomplete" ]; then
        echo "$incomplete" | rofi -dmenu -p "$prompt" -no-custom
    else
        rofi -dmenu -p "$prompt" < /dev/null
    fi
}

while true; do
    incomplete=$(grep '^- \[ \] ' "$file" | sed 's/^- \[ \] //')

    if [ -n "$incomplete" ]; then
        cmd=$(echo "$incomplete" | rofi -dmenu -p "$prompt")
    else
        cmd=$(rofi -dmenu -p "$prompt" < /dev/null)
    fi

    # Exit if nothing was entered (Escape pressed)
    [ -z "$cmd" ] && break

    # Check if the selected text matches an existing incomplete task
    matched=0
    while IFS= read -r line; do
        task="${line#- \[ \] }"
        if [ "$cmd" = "$task" ]; then
            matched=1
            break
        fi
    done <<EOF
$(grep '^- \[ \] ' "$file")
EOF

    if [ "$matched" = "1" ]; then
        # Mark the task as complete
        today=$(date +%Y-%m-%d)
        awk -v task="$cmd" -v d="$today" -v found=0 \
            '!found && $0 == "- [ ] " task { print "- [x] " task " (" d ")"; found=1; next } { print }' \
            "$file" > "$file.tmp" && mv "$file.tmp" "$file"
    else
        # Add a new task
        echo "- [ ] $cmd" >> "$file"
    fi
done

exit 0
